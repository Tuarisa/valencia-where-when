# Neon / Vercel Postgres connection string (pooled).
# Get it from the Neon dashboard or `vercel env pull`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret that protects the cron pipeline routes. Set the same value in Vercel
# and in the GitHub Actions `CRON_SECRET` secret used by .github/workflows/scheduler.yml.
CRON_SECRET="change-me-to-a-long-random-string"

# --- Card enrichment (sub-area E) ---
# Anthropic SDK is the primary enrichment engine (constrained decoding); required
# for the live enrich path and the live eval (`npm run eval`). Without it, the
# offline/mocked path and the `claude -p` (OAuth) fallback are used.
ANTHROPIC_API_KEY=""

# --- Notifications transport (sub-area G) ---
# Default is dry-run text output (no transport). To deliver for real, set a
# transport and its target. Supported: dry-run | telegram | webhook.
NOTIFY_TRANSPORT="dry-run"
# For telegram: a bot token + the private chat id the household reads.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# For webhook: a single POST endpoint that receives the digest payload.
NOTIFY_WEBHOOK_URL=""

# --- Local offline dev (sub-area H) ---
# When running against Docker Postgres behind the local Neon HTTP proxy, put this
# in .env.local. The neon() shim activates on the `db.localtest.me` host substring.
# DATABASE_URL="postgresql://postgres:postgres@db.localtest.me:5432/main"

# Base URL of the deployment the GitHub Actions scheduler POSTs to (repo secret).
# APP_BASE_URL="https://valencia-radar.vercel.app"
